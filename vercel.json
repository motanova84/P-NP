{
    "version": 2,
    "name": "p-vs-np-treewidth-framework",
    "rewrites": [
        {
            "source": "/demo",
            "destination": "/api/demo"
        },
        {
            "source": "/run_all",
            "destination": "/api/run_all"
        },
        {
            "source": "/simple",
            "destination": "/api/simple"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Project",
                    "value": "P≠NP Structural Dichotomy"
                },
                {
                    "key": "X-Theorem",
                    "value": "Lemma 6.24"
                },
                {
                    "key": "X-Framework",
                    "value": "Treewidth + Information Complexity"
                },
                {
                    "key": "X-Author",
                    "value": "JMMB Ψ✧"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/run_all",
            "schedule": "0 4 * * 1"
        },
        {
            "path": "/api/demo",
            "schedule": "15 4 * * 1"
        }
    ],
    "regions": [
        "fra1",
        "hnd1",
        "gru1"
    ]
}
